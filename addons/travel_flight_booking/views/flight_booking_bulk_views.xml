<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_flight_booking_bulk_wizard" model="ir.ui.view">
    <field name="name">flight.booking.bulk.upload.form</field>
    <field name="model">flight.booking.bulk.upload</field>
    <field name="arch" type="xml">
      <form string="Bulk Upload Flight Bookings">
        <sheet>
          <group>
            <field name="file" filename="filename"/>
          </group>
          <footer>
            <button string="Download sample Excel" type="object" name="action_download_sample" class="btn btn-secondary o_bulk_download_sample"/>
            <button string="Import" type="object" name="action_import" class="btn btn-primary"/>
            <button string="Cancel" class="btn btn-secondary" special="cancel"/>
          </footer>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action to open the wizard -->
  <record id="action_flight_booking_bulk_upload" model="ir.actions.act_window">
    <field name="name">Bulk Upload Flight Bookings</field>
    <field name="res_model">flight.booking.bulk.upload</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
    <field name="view_id" ref="view_flight_booking_bulk_wizard"/>
  </record>

  <!-- Menu item under Air Tickets -->
  <menuitem id="menu_flight_bulk_upload" name="Bulk Upload" parent="menu_travel_root" action="action_flight_booking_bulk_upload"/>
</odoo>
